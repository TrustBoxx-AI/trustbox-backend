[
  {
    "type": "function",
    "name": "registerAgent",
    "stateMutability": "payable",
    "inputs": [
      { "name": "agentId",     "type": "bytes32" },
      { "name": "teeEndpoint", "type": "string"  },
      { "name": "metadataURI", "type": "string"  }
    ],
    "outputs": [{ "name": "tokenId", "type": "uint256" }]
  },
  {
    "type": "function",
    "name": "getAgent",
    "stateMutability": "view",
    "inputs": [{ "name": "agentId", "type": "bytes32" }],
    "outputs": [
      { "name": "operator",    "type": "address" },
      { "name": "teeEndpoint", "type": "string"  },
      { "name": "metadataURI", "type": "string"  },
      { "name": "stake",       "type": "uint256" },
      { "name": "active",      "type": "bool"    },
      { "name": "tokenId",     "type": "uint256" }
    ]
  },
  {
    "type": "function",
    "name": "deregisterAgent",
    "stateMutability": "nonpayable",
    "inputs": [{ "name": "agentId", "type": "bytes32" }],
    "outputs": []
  },
  {
    "type": "function",
    "name": "createJob",
    "stateMutability": "payable",
    "inputs": [
      { "name": "agentId",    "type": "bytes32" },
      { "name": "bundleCID",  "type": "string"  },
      { "name": "callbackFn", "type": "bytes4"  }
    ],
    "outputs": [{ "name": "jobId", "type": "uint256" }]
  },
  {
    "type": "function",
    "name": "completeJob",
    "stateMutability": "nonpayable",
    "inputs": [
      { "name": "jobId",     "type": "uint256" },
      { "name": "resultCID", "type": "string"  },
      { "name": "resultHash","type": "bytes32" }
    ],
    "outputs": []
  },
  {
    "type": "function",
    "name": "totalAgents",
    "stateMutability": "view",
    "inputs": [],
    "outputs": [{ "name": "", "type": "uint256" }]
  },
  {
    "type": "event",
    "name": "AgentRegistered",
    "inputs": [
      { "name": "agentId",     "type": "bytes32", "indexed": true  },
      { "name": "operator",    "type": "address", "indexed": true  },
      { "name": "teeEndpoint", "type": "string",  "indexed": false },
      { "name": "tokenId",     "type": "uint256", "indexed": false }
    ]
  },
  {
    "type": "event",
    "name": "JobCreated",
    "inputs": [
      { "name": "jobId",     "type": "uint256", "indexed": true  },
      { "name": "agentId",   "type": "bytes32", "indexed": true  },
      { "name": "bundleCID", "type": "string",  "indexed": false }
    ]
  },
  {
    "type": "event",
    "name": "JobCompleted",
    "inputs": [
      { "name": "jobId",     "type": "uint256", "indexed": true  },
      { "name": "resultCID", "type": "string",  "indexed": false },
      { "name": "resultHash","type": "bytes32", "indexed": false }
    ]
  }
]